{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "http://www.cmu.edu/ai2c/schemas/bda.json",
    "title": "Battle Damage Assessment (BDA)",
    "description": "BDA generated by bda-svc",
    "type": "object",
    "properties": {
        "metadata": {
            "description": "BDA contextual information",
            "type": "object",
            "required": [
                "model_name",
                "image_id",
                "image_filename",
                "date_created",
                "location",
                "report_type",
                "analyst"
            ],
            "properties": {
                "model_name": {
                    "type": "string"
                },
                "image_id": {
                    "type": "string",
                    "format": "uuid"
                },
                "image_filename": {
                    "type": "string"
                },
                "date_created": {
                    "type": "string",
                    "format": "date-time"
                },
                "location": {
                    "type": "object",
                    "required": [
                        "crs",
                        "coordinates"
                    ],
                    "properties": {
                        "crs": {
                            "description": "Coordinate Reference System",
                            "type": "string"
                        },
                        "coordinates": {
                            "description": "Image location",
                            "type": "string"
                        }
                    }
                },
                "report_type": {
                    "type": "string",
                    "enum": ["PDA"]
                },
                "analyst": {
                    "type": "string"
                }
            }
        },
        "physical_damage": {
            "description": "A collection of damage assessments, keyed by target ID",
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
                "description": "Damage assessment for a single target",
                "type": "object",
                "required": [
                    "target_type",
                    "damage_category",
                    "confidence_level",
                    "brief_supporting_logic"
                ],
                "properties": {
                    "bounding_box": {
                        "description": "Image coordinates of the detected object",
                        "type": "object",
                        "required": [
                            "xmin",
                            "ymin",
                            "xmax",
                            "ymax"
                        ],
                        "properties": {
                            "xmin": {
                                "description": "Left side of rectangle",
                                "type": "integer",
                                "minimum": 0
                            },
                            "ymin": {
                                "description": "Top side of rectangle",
                                "type": "integer",
                                "minimum": 0
                            },
                            "xmax": {
                                "description": "Right side of rectangle",
                                "type": "integer",
                                "minimum": 0
                            },
                            "ymax": {
                                "description": "Bottom side of rectangle",
                                "type": "integer",
                                "minimum": 0
                            }
                        }
                    },
                    "target_type": {
                        "type": "string",
                        "enum": [
                            "bridges",
                            "buildings",
                            "bunkers",
                            "dams_and_locks",
                            "distillation_towers",
                            "electronic_data_and_information_technology_systems",
                            "ground_force_personnel_military_units",
                            "ground_force_personnel_individuals",
                            "military_equipment",
                            "petroleum_oil_lubricants_storage_tanks",
                            "power_plant_turbines_and_generators",
                            "rail_lines_and_rail_yards",
                            "roads",
                            "runways_and_taxiways",
                            "satellite_dishes",
                            "ships",
                            "steel_towers",
                            "transformers",
                            "tunnel_entrances_or_portals",
                            "tunnel_facility_air_vents",
                            "object_not_found"
                        ]
                    },
                    "damage_category": {
                        "$comment": "Defined below (conditionally)",
                        "type": "string"
                    },
                    "confidence_level": {
                        "type": "string",
                        "enum": [
                            "CONFIRMED",
                            "PROBABLE",
                            "POSSIBLE"
                        ]
                    },
                    "brief_supporting_logic": {
                        "type": "string"
                    }
                },
                "allOf": [
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "enum": [
                                        "bridges",
                                        "buildings",
                                        "bunkers",
                                        "satellite_dishes",
                                        "tunnel_entrances_or_portals"
                                    ]
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "NO DAMAGE",
                                        "LIGHT DAMAGE",
                                        "MODERATE DAMAGE",
                                        "SEVERE DAMAGE",
                                        "DESTROYED"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "enum": [
                                        "dams_and_locks",
                                        "military_equipment",
                                        "power_plant_turbines_and_generators",
                                        "steel_towers",
                                        "transformers",
                                        "tunnel_facility_air_vents"
                                    ]
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "NO DAMAGE",
                                        "DAMAGED",
                                        "DESTROYED"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "const": "distillation_towers"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "NO DAMAGE",
                                        "LIGHT DAMAGE",
                                        "MODERATE DAMAGE",
                                        "DESTROYED"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "const": "electronic_data_and_information_technology_systems"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "NO EFFECT",
                                        "MANIPULATED",
                                        "DEGRADED",
                                        "DISRUPTED",
                                        "DESTROYED"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "const": "ground_force_personnel_military_units"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "NO DAMAGE",
                                        "ATTRITED",
                                        "SEVERELY ATTRITED"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "const": "ground_force_personnel_individuals"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "UNHARMED",
                                        "CAPTURED",
                                        "WOUNDED",
                                        "KILLED"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "const": "petroleum_oil_lubricants_storage_tanks"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "NO DAMAGE",
                                        "LIGHT-MODERATE DAMAGE",
                                        "DESTROYED"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "const": "rail_lines_and_rail_yards"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "NO DAMAGE",
                                        "CUT",
                                        "DESTROYED"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "const": "roads"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "NO DAMAGE",
                                        "CRATERED",
                                        "CUT"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "const": "runways_and_taxiways"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "NO DAMAGE",
                                        "CRATERED",
                                        "CUT",
                                        "INTERDICTED"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "const": "ships"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "enum": [
                                        "NO DAMAGE",
                                        "MODERATE DAMAGE",
                                        "SEVERE DAMAGE",
                                        "DESTROYED"
                                    ]
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "target_type": {
                                    "const": "object_not_found"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "damage_category": {
                                    "type": "string",
                                    "const": "NOT APPLICABLE"
                                }
                            }
                        }
                    }
                ]
            }
        },
        "functional_damage": {
            "description": "Functional damage assessment",
            "type": "object",
            "properties": {
                "functional_damage_level": {
                    "type": "string",
                    "enum": [
                        "NO FUNCTIONAL DAMAGE",
                        "LIGHT FUNCTIONAL DAMAGE",
                        "MODERATE FUNCTIONAL DAMAGE",
                        "SEVERE FUNCTIONAL DAMAGE",
                        "FUNCTIONALLY DESTROYED",
                        "ABANDONED",
                        "UNKNOWN FUNCTIONAL DAMAGE"
                    ]
                },
                "brief_supporting_logic": {
                    "type": "string"
                }
            },
            "required": ["functional_damage_level"]
        },
        "summary": {
            "description": "Scene summary",
            "type": "string"

        }
    },
    "required": ["metadata", "physical_damage"]
}